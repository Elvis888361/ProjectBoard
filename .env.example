# Copy to .env and adjust. `docker compose up` works without this file -- the compose
# file has dev defaults for everything below.

# Postgres connection string used by the API.
DATABASE_URL=postgresql://taskboard:taskboard@localhost:5432/taskboard

# Signs session tokens. There is NO default in the app: it must be set, or the API
# refuses to start. Generate one with:  openssl rand -hex 32
JWT_SECRET=

# Set to true in production (requires HTTPS). False for local http://localhost.
COOKIE_SECURE=false

# How long a session lasts. 12h -- see ARCHITECTURE.md on why there's no refresh token.
ACCESS_TOKEN_TTL_MINUTES=720

# Login attempts allowed per IP per window.
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Only needed if the SPA is served from a DIFFERENT origin than the API. Empty in dev
# and in the docker-compose setup, because nginx/Vite proxy the API under the same
# origin -- which is what lets the session cookie work without CORS.
# CORS_ORIGINS=["https://board.example.com"]
